{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "local-debug",
      "displayName": "Local ARM GCC Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "${sourceDir}/cmake/arm-none-eabi-gcc.cmake",
      "environment": {
        "ARM_GNU_TOOLCHAIN_DIR": "${sourceDir}/.tools/arm-gnu-toolchain-15.2.rel1-x86_64-arm-none-eabi"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "local-debug",
      "configurePreset": "local-debug",
      "targets": [
        "firmware.elf",
        "firmware_quad.elf"
      ]
    }
  ]
}
